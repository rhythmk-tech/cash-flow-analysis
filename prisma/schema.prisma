generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  companyName  String
  createdAt    DateTime @default(now())

  // When this account holder agreed to the Terms of Service / Privacy Policy at signup. Null
  // for accounts created before this was tracked — nothing is backfilled, since we can't
  // actually know whether/when they agreed.
  termsAcceptedAt DateTime?

  // Grants access to /admin — aggregate, cross-company usage analytics for operating the
  // product. Deliberately separate from the in-company owner/admin/editor/viewer roles above,
  // which only ever govern a single company's own data. Not settable through any UI; set
  // directly in the database for whichever account(s) should have it.
  isPlatformAdmin Boolean @default(false)

  // Forecast settings — only meaningful when this user IS a company (activeCompanyId is null).
  // Members who joined another company via invite read/write the owner's row instead.
  startingBalance Float    @default(0)
  totalWeeks      Int      @default(12)
  bearPct         Float    @default(-10)
  bullPct         Float    @default(10)
  forecastStart   DateTime @default(now())

  // Manual drag-and-drop order for Detailed Forecast rows, as an ordered list of lineLabels.
  // Empty means "no custom order yet" — rows fall back to first-seen order, matching the
  // behavior every existing account already has today. Any label not present here (e.g. a
  // brand-new item) is appended after the ordered ones. See lib/forecast.ts's sortLabels.
  incomeRowOrder  String[] @default([])
  expenseRowOrder String[] @default([])

  // If set, this user operates on another user's (the "company owner's") data instead of
  // their own. Null means this user is their own company.
  activeCompanyId String?
  companyOwner    User?    @relation("CompanyMembers", fields: [activeCompanyId], references: [id], onDelete: SetNull)
  members         User[]   @relation("CompanyMembers")

  // Only meaningful when activeCompanyId is set (i.e. this row is a team member, not an owner).
  // "admin" | "editor" | "viewer" — see lib/roles.ts. The owner's own permissions are implicit
  // and not stored here.
  role String @default("editor")

  // Tracks the last negative-balance alert email sent for this company, so a mutation that
  // leaves the same week still-negative doesn't re-fire the email every time. See lib/alerts.ts.
  lastNegativeAlertWeek Int?
  lastNegativeAlertAt   DateTime?

  // Data owned by this row when it is acting as a company (activeCompanyId is null on the owner).
  items     LineItem[]
  overrides Override[]
  actuals   Actual[]

  passwordResetTokens PasswordResetToken[]
}

model Invitation {
  id         String    @id @default(cuid())
  companyId  String // the User.id whose company this invite grants access to
  email      String
  role       String    @default("editor") // "admin" | "editor" | "viewer" — copied to User.role on acceptance
  token      String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  @@index([companyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([userId])
}

model LineItem {
  id        String   @id @default(cuid())
  userId    String // company owner's User.id, not necessarily the creator
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "income" | "expense"
  category  String
  name      String
  amount    Float
  frequency String // "onetime" | "weekly" | "biweekly" | "monthly"
  startDate DateTime // absolute calendar date this item first occurs — NOT relative to forecastStart,
  // so editing the forecast's Week-1 start date never silently moves an item's real-world date.
  // Its position within the current forecast window is recomputed on the fly (see occurrencesFor).
  lineLabel String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Override {
  id     String @id @default(cuid())
  userId String // company owner's User.id, not necessarily the creator
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   String // "income" | "expense"
  label  String
  week   Int
  value  Float

  @@unique([userId, type, label, week])
  @@index([userId])
}

// One entry per mutation a team member makes, for accountability once more than one person
// can edit a company's data. actorEmail is denormalized so history stays readable even after
// the actor is later removed from the team.
model ActivityLog {
  id          String   @id @default(cuid())
  companyId   String
  actorUserId String
  actorEmail  String
  action      String
  summary     String
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
}

// A user-reported actual closing balance for a past week, compared against what the forecast
// predicted for that week to show how accurate the model has been.
model Actual {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  week      Int
  // Each independently optional — a week can have any subset recorded (e.g. actual income
  // known before the exact closing balance is checked). balance was previously required;
  // loosening it to optional keeps every existing row's value exactly as it was.
  balance   Float?
  income    Float?
  expense   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, week])
  @@index([userId])
}
